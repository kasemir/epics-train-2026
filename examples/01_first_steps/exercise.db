# Run as
#       softIoc -m S=demo -d exercise.db

record(ao, "$(S):limit")
{
   field(DRVH, "100")
   field(DOL,  "10")
   field(PINI, "YES")
}

# .PROC this record to reset limit to 10
record(ao, "$(S):reset")
{
   field(DOL, "10")
   field(OUT, "$(S):limit PP")
}

record(ao, "$(S):step")
{
   field(DRVH, "5")
   field(DRVL, "0.1")
   field(DOL,  "1")
   field(PREC, "1")
   field(PINI, "YES")
}

record(bo, "$(S):double")
{
   field(ZNAM, "Normal")
   field(ONAM, "Double")
   field(HIGH, "5")
}

record(calc, "$(S):ramp")
{
   field(SCAN, "1 second")
   field(INPA, "$(S):ramp")
   field(INPB, "$(S):limit")
   field(INPC, "$(S):step")
   field(INPD, "$(S):double")
   field(CALC, "A<B ? A+(D?2*C:C) : 0")
   field(EGU,  "a.u.")
   field(PREC, "2")
   field(HIGH, "8")
   field(HSV,  "MINOR")
   field(ADEL, "2")
}

